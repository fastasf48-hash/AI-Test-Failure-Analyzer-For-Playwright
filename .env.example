# Copy this file to `.env` and fill in the values you need.
# Nothing in this project reads these keys until you explicitly run
# `python analyze_failure.py` or click "Analyze Failure" in the dashboard.

# --- Choose which provider "Analyze Failure" uses -----------------------------
# One of: openai, claude
LLM_PROVIDER=openai

# --- Provider credentials (only the one matching LLM_PROVIDER is required) ----
OPENAI_API_KEY=
CLAUDE_API_KEY=

# --- Optional model overrides --------------------------------------------------
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-sonnet-5

# --- Optional storage overrides (sensible defaults if omitted) ---------------
DATABASE_URL=
ARTIFACTS_DIR=
LOG_LEVEL=INFO
LOG_DIR=
