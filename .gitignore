# --- Secrets & environment ------------------------------------------------
.env
*.env

# --- Python -----------------------------------------------------------------
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Test / AI artifacts (can be large and are always regenerable) --------
# Anchored to the repo root (leading slash) — unanchored `reports/` also
# matched app/reports/, silently excluding that source package from git.
/reports/
logs/*
!logs/.gitkeep
allure-results/
allure-report/
playwright-report/
test-results/
trace/
videos/
screenshots/
data/artifacts/*
!data/artifacts/.gitkeep
data/*.db
data/*.sqlite
*.sqlite
*.db

# --- IDE ----------------------------------------------------------------------
.idea/
.vscode/
.claude/

# --- Personal interview prep (never published) ------------------------------
INTERVIEW_PREP_GUIDE.md
